# Local development secrets for `wrangler dev`.
# Copy to `.dev.vars` and fill in. NEVER commit `.dev.vars`.

# Required: Gemini API key (server-side only, never exposed to clients).
GEMINI_API_KEY=your-gemini-api-key

# Optional overrides (defaults live in wrangler.jsonc [vars]):
# GEMINI_MODEL=gemini-2.5-flash
# ALLOWED_ORIGINS=*
# DEFAULT_LANGUAGE=en
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_SECONDS=60
# MAX_IMAGE_BYTES=8388608
